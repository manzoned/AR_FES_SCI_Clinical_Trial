  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "The purpose of the feedback is to show you the comparison between your
    grasping posture and the target grasping posture. The first way you will get
    feedback is by showing you an error score in the middle of the screen. The error
    score compares the position/angle of each of your joints to the position/angle
    of the target hand. This will provide information on the overall error (labeled
    as mean angular error) and the finger with the largest error. The goal is to
    get the lowest error possible. The colour of the text will also help you visualize
    the error. This is on a green to red scale with lower errors being more green
    and higher errors being more red. To see the feedback say \u201Cperformance\u201D
    or \u201Cscore\u201D. See the example on the right."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 6a84f857bec7e7345843ae29404c57ce, type: 2}
